#: exception.py:7
msgid "Conversion failed"
msgstr "Неуспешна конвертация"

#: exception.py:8
msgid ""
"Unable to convert the file into 3D Tiles. There is some problem with the file"
" or it may be corrupted during upload."
msgstr ""
"Неуспешно преобразуване в 3D плочки. Има проблем във файла или се е повредил "
"при прикачване."

#: model.py:42 nodepkg/editor-widget/EditorWidget.js:47 view.py:18

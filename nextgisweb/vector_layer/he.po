#: ogrloader.py:332
#, python-format, server
msgid "Field '%s' is out of int32 range."
msgstr "השדה '%s' מחוץ לטווח int32."

#: ogrloader.py:340
#, python-format, server
msgid "Field '%s' contains non-unique or empty values."
msgstr "השדה '%s' מכיל ערכים לא ייחודיים או ערכים ריקים."

#: ogrloader.py:357
#, server
msgid "Parameter 'fid_field' is missing."
msgstr "הפרמטר 'fid_field' חסר."

#: ogrloader.py:360
#, python-format, server
msgid "Fields %s not found."
msgstr "שדות %s לא נמצאו."

#: ogrloader.py:362
#, python-format, server
msgid "None of fields %s are integer."
msgstr "אף אחד מהשדות %s אינו מספר שלם."

#: ogrloader.py:376
#, python-format, server
msgid "Field '%s(?)' encoding is broken."
msgstr "קידוד השדה '%s(?)' פגום."

#: ogrloader.py:393
#, python-format, server
msgid "Unsupported field type: %r."
msgstr "סוג שדה לא נתמך: %r."

#: ogrloader.py:419
#, server
msgid ""
"The source layer has a local coordinate system and can't be reprojected to "
"the target coordinate system."
msgstr ""
"לשכבת המקור יש מערכת קואורדינטות מקומית ולא ניתן להקרין אותה מחדש למערכת "
"הקואורדינטות של היעד."

#: ogrloader.py:504
#, python-format, server
msgid ""
"Feature #%d has a geometry that can't be reprojected to target coordinate "
"system"
msgstr "לתכונה #%d יש גיאומטריה שלא ניתן להטיל אותה מחדש למערכת הקואורדינטות היעד."

#: ogrloader.py:549
#, server
msgid "Vector layer cannot be written due to errors."
msgstr "לא ניתן לכתוב את שכבת הווקטור עקב שגיאות."

#: ogrloader.py:575
#, python-format, server
msgid "Feature (seq. #%d) doesn't have a FID field '%s'."
msgstr "לתכונה (seq. #%d) אין שדה FID '%s'."

#: ogrloader.py:579
#, python-format, server
msgid "Feature (seq. #%d) FID field '%s' is null."
msgstr "שדה ה-FID '%s' של המאפיין (seq. #%d) הוא ריק."

#: ogrloader.py:626 ogrloader.py:665
#, python-format, server
msgid "Feature #%d has multiple geometries satisfying the conditions."
msgstr "לתכונה #%d יש מספר גיאומטריות העונות על התנאים."

#: ogrloader.py:636
#, python-format, server
msgid "Feature #%d has unknown geometry type: %d (%s)."
msgstr "לתכונה #%d יש סוג גיאומטרי לא ידוע: %d (%s)."

#: ogrloader.py:645
#, python-format, server
msgid "Feature #%d has unsuitable geometry type: %d (%s)."
msgstr "לתכונה #%d יש סוג גיאומטרי לא מתאים: %d (%s)."

#: ogrloader.py:683
#, python-format, server
msgid "Feature #%d has empty rings."
msgstr "לתכונה #%d יש טבעות ריקות."

#: ogrloader.py:694
#, python-format, server
msgid "Feature #%d has unclosed rings."
msgstr "לתכונה #%d יש טבעות לא סגורות."

#: ogrloader.py:704
#, python-format, server
msgid "Feature #%d has less than 3 points in a polygon ring."
msgstr "לתכונה #%d יש פחות מ-3 נקודות בטבעת פוליגון."

#: ogrloader.py:716
#, python-format, server
msgid "Feature #%d contains an empty linestring."
msgstr "תכונה #%d מכילה מחרוזת שורה ריקה."

#: ogrloader.py:722
#, python-format, server
msgid "Feature #%d has less than 2 points in a linestring."
msgstr "לתכונה #%d יש פחות מ-2 נקודות במחרוזת שורה."

#: ogrloader.py:739
#, python-format, server
msgid "Feature #%d contains a broken encoding of field '%s'."
msgstr "תכונה #%d מכילה קידוד פגום של השדה '%s'."

#: util.py:64
#, server
msgid ""
"ESRI Shapefile (zip), GeoPackage, GeoJSON, GML, KML, CSV or XLSX formats are "
"supported. For CSV and XLSX only points are supported, coordinates must be "
"put in lat and lot columns."
msgstr ""
"תמיכה בפורמטים של ESRI Shapefile (zip), GeoPackage, GeoJSON, GML, KML, CSV או"
" XLSX. עבור CSV ו-XLSX נתמכות רק נקודות, יש להזין קואורדינטות בעמודות lat "
"ו-lot."

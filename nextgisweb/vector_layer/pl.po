msgstr "Nieobsługiwany typ pola: %r."

#: ogrloader.py:417
msgid ""
"The source layer has a local coordinate system and can't be reprojected to "
"the target coordinate system."
msgstr ""
"Warstwa źródłowa ma lokalny układ współrzędnych i nie może być przekształcona"
" do docelowego układu współrzędnych."

#: ogrloader.py:500
msgid ""
"Feature #%d has a geometry that can't be reprojected to target coordinate "
"system"
msgstr ""
"Obiekt #%d ma geometrię, której nie można przekształcić do docelowego układu "
"współrzędnych"

#: ogrloader.py:545
msgid "Vector layer cannot be written due to errors."
msgstr "Warstwa wektorowa nie może zostać zapisana z powodu błędów."

#: ogrloader.py:571
msgid "Feature (seq. #%d) doesn't have a FID field '%s'."
msgstr "Obiekt (seq. #%d) nie ma pola FID '%s'."

#: ogrloader.py:575
msgid "Feature (seq. #%d) FID field '%s' is null."
msgstr "Obiekt (seq. #%d) ma puste pole FID '%s'."

#: ogrloader.py:622 ogrloader.py:661
msgid "Feature #%d has multiple geometries satisfying the conditions."
msgstr "Obiekt #%d ma wiele geometrii spełniających warunki."

#: ogrloader.py:632
msgid "Feature #%d has unknown geometry type: %d (%s)."
msgstr "Obiekt #%d ma nieznany typ geometrii: %d (%s)."

#: ogrloader.py:641
msgid "Feature #%d has unsuitable geometry type: %d (%s)."
msgstr "Obiekt #%d ma nieodpowiedni typ geometrii: %d (%s)."

#: ogrloader.py:679
msgid "Feature #%d has empty rings."
msgstr "Obiekt #%d zawiera puste pierścienie."

#: ogrloader.py:690
msgid "Feature #%d has unclosed rings."
msgstr "Obiekt #%d ma niezamknięte pierścienie."

#: ogrloader.py:700
msgid "Feature #%d has less than 3 points in a polygon ring."
msgstr "Obiekt #%d ma mniej niż 3 punkty w pierścieniu poligonu."

#: ogrloader.py:712
msgid "Feature #%d contains an empty linestring."
msgstr "Obiekt #%d zawiera pustą linię."

#: ogrloader.py:718
msgid "Feature #%d has less than 2 points in a linestring."
msgstr "Obiekt #%d ma mniej niż 2 punkty w linii."

#: ogrloader.py:735
msgid "Feature #%d contains a broken encoding of field '%s'."
msgstr "Obiekt #%d zawiera uszkodzone kodowanie pola '%s'."

#: util.py:54
msgid ""
"ESRI Shapefile (zip), GeoPackage, GeoJSON, GML, KML, CSV or XLSX formats are "
"supported. For CSV and XLSX only points are supported, coordinates must be "
"put in lat and lot columns."
msgstr ""
"Obsługiwane formaty ESRI Shapefile (zip), GeoPackage, GeoJSON, GML, KML, CSV "
"lub XLSX obsługiwane są tylko punkty. Współrzędne muszą znajdować się w "
"kolumnach lat i lon."

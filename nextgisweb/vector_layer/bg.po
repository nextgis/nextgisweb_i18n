#: ogrloader.py:314
msgid ""
"The source layer contains no suitable features, or contains features of "
"different geometry types."
msgstr ""

#: ogrloader.py:332
msgid "Field '%s' is out of int32 range."
msgstr "Полето %s не е в диапазона от тип данни Int32."

#: ogrloader.py:340
msgid "Field '%s' contains non-unique or empty values."
msgstr "Полето %s е празно или има неуникална стойност."

#: ogrloader.py:357
msgid "Parameter 'fid_field' is missing."
msgstr "Параметърът 'fid_field' не е налице."

#: ogrloader.py:360
msgid "Fields %s not found."
msgstr "Полета %s не са открити."

#: ogrloader.py:362

msgstr "Нито едно от полета %s не е цялочислено."

#: ogrloader.py:376
msgid "Field '%s(?)' encoding is broken."
msgstr "Кодировката на полето  '%s(?)' е счупена."

#: ogrloader.py:391
msgid "Unsupported field type: %r."
msgstr "Този тип поле не е поддържан: %r."

#: ogrloader.py:417
msgid ""
"The source layer has a local coordinate system and can't be reprojected to "
"the target coordinate system."
msgstr ""
"Изходният слой има локална координатна система и не може да бъде модифициран "
"в целевата координатна система."

#: ogrloader.py:500
msgid ""
"Feature #%d has a geometry that can't be reprojected to target coordinate "
"system"
msgstr ""
"Обектът #%d има геометрия, която не може да бъде модифицирана в избраната "
"координатна система"

#: ogrloader.py:545
msgid "Vector layer cannot be written due to errors."
msgstr "Векторният слой не може да бъде записан поради грешки."

#: ogrloader.py:571
msgid "Feature (seq. #%d) doesn't have a FID field '%s'."
msgstr "Обектът (seq. #%d) няма поле FID '%s'."

#: ogrloader.py:575
msgid "Feature (seq. #%d) FID field '%s' is null."
msgstr "Обектът (seq. #%d) съдържа празно поле FID '%s'."

#: ogrloader.py:622 ogrloader.py:661
msgid "Feature #%d has multiple geometries satisfying the conditions."
msgstr "Обектът #%d има няколко геометрии, отговарящи на условията."

#: ogrloader.py:632
msgid "Feature #%d has unknown geometry type: %d (%s)."
msgstr "Обектът #%d има неизвестен тип геометрия: %d (%s)."

#: ogrloader.py:641
msgid "Feature #%d has unsuitable geometry type: %d (%s)."
msgstr "Обектът #%d има неподходящ тип геометрия: %d (%s)."

#: ogrloader.py:679
msgid "Feature #%d has empty rings."
msgstr "Обектът #%d има празни пръстени."

#: ogrloader.py:690
msgid "Feature #%d has unclosed rings."
msgstr "В обекта #%d има незатворени пръстени."

#: ogrloader.py:700
msgid "Feature #%d has less than 3 points in a polygon ring."
msgstr "Обектът #%d има по-малко от 3 точки в пръстен на полигона."

#: ogrloader.py:712
msgid "Feature #%d contains an empty linestring."
msgstr "Обектът #%d съдържа празна линия."

#: ogrloader.py:718
msgid "Feature #%d has less than 2 points in a linestring."
msgstr "Обектът #%d има по-малко от 2 точки в линията."

#: ogrloader.py:735
msgid "Feature #%d contains a broken encoding of field '%s'."
msgstr "Обект #%d съдържа счупена кодировка в поле '%s'."

#: util.py:54
msgid ""
"ESRI Shapefile (zip), GeoPackage, GeoJSON, GML, KML, CSV or XLSX formats are "
"supported. For CSV and XLSX only points are supported, coordinates must be "
"put in lat and lot columns."
msgstr ""
"Поддържани формати: ESRI Shapefile (zip), GeoPackage, GeoJSON, GML, KML, CSV "
"или XLSX. За CSV и XLSX се поддържат само точки, координатите трябва да са в "
"колони 'lat' и 'lon'."
